@using ElectionSim.Core.Models
@using ElectionSim.Web.Services

<div class="flipped-ridings-table">
    <h3>Projected Flips <span class="subtitle">Ridings where simulation projects a different winner than current holder</span></h3>

    @if (Summary != null && Ridings != null)
    {
        var flippedRidings = GetFlippedRidings();
        @if (flippedRidings.Count > 0)
        {
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            @{
                                var provCls = HeaderClass(ColProvince, "col-province");
                                var provInd = SortIndicator(ColProvince);
                                var ridCls = HeaderClass(ColRiding, "col-riding");
                                var ridInd = SortIndicator(ColRiding);
                                var fromCls = HeaderClass(ColFrom, "col-from");
                                var fromInd = SortIndicator(ColFrom);
                                var toCls = HeaderClass(ColTo, "col-to");
                                var toInd = SortIndicator(ColTo);
                                var wpCls = HeaderClass(ColWinProb, "col-winprob");
                                var wpInd = SortIndicator(ColWinProb);
                            }
                            <th class="@provCls" @onclick="() => SortBy(ColProvince)">
                                Province@(provInd)
                            </th>
                            <th class="@ridCls" @onclick="() => SortBy(ColRiding)">
                                Riding@(ridInd)
                            </th>
                            <th class="@fromCls" @onclick="() => SortBy(ColFrom)">
                                From@(fromInd)
                            </th>
                            <th class="@toCls" @onclick="() => SortBy(ColTo)">
                                To@(toInd)
                            </th>
                            <th class="@wpCls" @onclick="() => SortBy(ColWinProb)">
                                Win%@(wpInd)
                            </th>
                            @foreach (var party in PartyColorProvider.MainParties)
                            {
                                var partyKey = party.ToString();
                                var partyCls = HeaderClass(partyKey);
                                var partyInd = SortIndicator(partyKey);
                                <th class="@partyCls"
                                    style="color: @PartyColorProvider.GetColor(party)"
                                    @onclick="() => SortBy(partyKey)">
                                    @PartyColorProvider.GetShortName(party)@partyInd
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in flippedRidings)
                        {
                            var fromColor = PartyColorProvider.GetColor(entry.PreviousWinner);
                            var toColor = PartyColorProvider.GetColor(entry.ProjectedWinner);
                            <tr @onclick="() => OnRidingSelected.InvokeAsync(entry.Riding)">
                                <td class="col-province">@entry.Riding.Province</td>
                                <td class="col-riding">@entry.Riding.Name</td>
                                <td class="col-from">
                                    <span class="party-badge" style="background: @(fromColor)22; color: @fromColor; border: 1px solid @(fromColor)44">
                                        @PartyColorProvider.GetShortName(entry.PreviousWinner)
                                    </span>
                                </td>
                                <td class="col-to">
                                    <span class="party-badge" style="background: @(toColor)22; color: @toColor; border: 1px solid @(toColor)44">
                                        @PartyColorProvider.GetShortName(entry.ProjectedWinner)
                                    </span>
                                </td>
                                <td class="col-winprob">@((entry.ProjectedWinProb * 100).ToString("F1"))%</td>
                                @foreach (var party in PartyColorProvider.MainParties)
                                {
                                    @if (entry.VoteShares.TryGetValue(party, out var vs) && vs.Median >= 1.0)
                                    {
                                        <td class="vote-cell" style="color: @PartyColorProvider.GetColor(party)">
                                            @vs.Median.ToString("F1") <span class="pm">±@vs.HalfIqr.ToString("F1")</span>
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="vote-cell empty">—</td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="count-label">@flippedRidings.Count projected @(flippedRidings.Count == 1 ? "flip" : "flips")</div>
        }
        else
        {
            <p class="no-flips">No projected flips — all ridings are projected to hold.</p>
        }
    }
</div>
