@using ElectionSim.Core.Models
@using ElectionSim.Web.Services
@inject DataService DataService
@inject SimulationState State

<div class="seat-chart">
    <h3>Projected Seat Count</h3>

    @if (Summary != null)
    {
        var currentSeats = GetCurrentSeats();
        var vacantCount = GetVacantSeatCount();

        <div class="majority-line-label">
            <span>Majority: 172</span>
        </div>

        @foreach (var party in PartyColourProvider.MainParties)
        {
            if (!Summary.SeatDistributions.TryGetValue(party, out var dist)) continue;
            if (dist.Max < 1) continue;

            var colour = PartyColourProvider.GetColour(party);
            double maxSeats = Summary.SeatDistributions.Values.Max(d => d.Max);
            double scale = maxSeats > 0 ? 100.0 / maxSeats : 1;
            double meanPct = dist.Mean * scale;
            double p5Pct = dist.P5 * scale;
            double p25Pct = dist.P25 * scale;
            double p75Pct = dist.P75 * scale;
            double p95Pct = dist.P95 * scale;
            double majorityPct = 172.0 * scale;

            var breakdown = currentSeats.GetValueOrDefault(party);
            var currentTotal = breakdown?.Total ?? 0;

            <div class="bar-row">
                <div class="bar-label">
                    <span class="party-name" style="color: @colour">@PartyColourProvider.GetName(party)</span>
                    <span class="seat-mean-group">
                        <span class="seat-mean">@dist.Mean.ToString("F0")</span>@{
                            var delta = (int)Math.Round(dist.Mean) - currentTotal;
                        }@if (delta > 0)
                        {<span class="seat-delta" style="color: #16a34a">▲@delta</span>}
                        else if (delta < 0)
                        {<span class="seat-delta" style="color: #dc2626">▼@Math.Abs(delta)</span>}
                    </span>
                </div>
                <div class="bar-container">
                    @* 95% CI *@
                    <div class="ci-95" style="left: @(p5Pct)%; width: @(p95Pct - p5Pct)%; background: @(colour)22;"></div>
                    @* 68% CI (P25-P75) *@
                    <div class="ci-68" style="left: @(p25Pct)%; width: @(p75Pct - p25Pct)%; background: @(colour)66;"></div>
                    @* Mean marker *@
                    <div class="mean-marker" style="left: @(meanPct)%; background: @colour;"></div>
                    @* Majority line *@
                    <div class="majority-line" style="left: @(majorityPct)%;"></div>
                    @* Hover value labels *@
                    <span class="bar-value" style="left: @(p5Pct)%">@dist.P5</span>
                    <span class="bar-value" style="left: @(p25Pct)%">@dist.P25</span>
                    <span class="bar-value" style="left: @(p75Pct)%">@dist.P75</span>
                    <span class="bar-value" style="left: @(p95Pct)%">@dist.P95</span>
                </div>
                <div class="bar-range">
                    @dist.P5 - @dist.P95
                    @if (breakdown != null)
                    {
                        var parts = new List<string>();
                        parts.Add($"{breakdown.Elected} elected");
                        if (breakdown.FloorCrossingGains > 0) parts.Add($"+{breakdown.FloorCrossingGains} crossed");
                        if (breakdown.FloorCrossingLosses > 0) parts.Add($"\u2212{breakdown.FloorCrossingLosses} crossed");
                        if (breakdown.ByElectionGains > 0) parts.Add($"+{breakdown.ByElectionGains} by-election");
                        if (breakdown.ByElectionLosses > 0) parts.Add($"\u2212{breakdown.ByElectionLosses} by-election");
                        if (breakdown.Vacancies > 0) parts.Add($"\u2212{breakdown.Vacancies} vacated");
                        <span class="seat-annotation">(@string.Join(", ", parts))</span>
                    }
                </div>
            </div>
        }

        @if (vacantCount > 0)
        {
            <div class="vacant-annotation">Vacant: @vacantCount @(vacantCount == 1 ? "seat" : "seats")</div>
        }
    }
    else
    {
        <div class="placeholder">Run a simulation to see projected seat counts.</div>
    }
</div>

@code {
    [Parameter] public SimulationSummary? Summary { get; set; }

    private record SeatBreakdown(int Total, int Elected, int FloorCrossingGains, int FloorCrossingLosses, int ByElectionGains, int ByElectionLosses, int Vacancies);

    private Dictionary<Party, SeatBreakdown> GetCurrentSeats()
    {
        var parlState = State.CurrentParliamentaryState;
        if (parlState == null || parlState.Count == 0) return new();

        var elected = new Dictionary<Party, int>();
        var crossGains = new Dictionary<Party, int>();
        var crossLosses = new Dictionary<Party, int>();
        var byElectionGains = new Dictionary<Party, int>();
        var byElectionLosses = new Dictionary<Party, int>();
        var vacancies = new Dictionary<Party, int>();

        foreach (var (_, status) in parlState)
        {
            // Count election winners
            elected.TryGetValue(status.ElectionWinner, out var ec);
            elected[status.ElectionWinner] = ec + 1;

            if (status.CurrentHolder == null)
            {
                // Seat is vacant — attribute loss to the party from the vacancy/annulment event
                var vacancyEvent = status.Events.LastOrDefault(e => e.Type == PostElectionEventType.Vacancy || e.Type == PostElectionEventType.Annulled);
                var lostBy = vacancyEvent?.FromParty ?? status.ElectionWinner;
                vacancies.TryGetValue(lostBy, out var vc);
                vacancies[lostBy] = vc + 1;

                // If there was a floor crossing before the vacancy, still count that transition
                if (status.IsFloorCrosser && lostBy != status.ElectionWinner)
                {
                    crossGains.TryGetValue(lostBy, out var cg);
                    crossGains[lostBy] = cg + 1;
                    crossLosses.TryGetValue(status.ElectionWinner, out var cl);
                    crossLosses[status.ElectionWinner] = cl + 1;
                }
            }
            else if (status.IsFloorCrosser && status.CurrentHolder != status.ElectionWinner)
            {
                // Floor crossing gain for new party
                crossGains.TryGetValue(status.CurrentHolder.Value, out var cg);
                crossGains[status.CurrentHolder.Value] = cg + 1;
                // Floor crossing loss for original party
                crossLosses.TryGetValue(status.ElectionWinner, out var cl);
                crossLosses[status.ElectionWinner] = cl + 1;
            }
            else if (status.HasByElection && status.CurrentHolder != status.ElectionWinner)
            {
                // By-election changed hands
                byElectionGains.TryGetValue(status.CurrentHolder.Value, out var bg);
                byElectionGains[status.CurrentHolder.Value] = bg + 1;
                // By-election loss for original party
                byElectionLosses.TryGetValue(status.ElectionWinner, out var bl);
                byElectionLosses[status.ElectionWinner] = bl + 1;
            }
        }

        var result = new Dictionary<Party, SeatBreakdown>();
        var allParties = elected.Keys
            .Union(crossGains.Keys).Union(crossLosses.Keys)
            .Union(byElectionGains.Keys).Union(byElectionLosses.Keys)
            .Union(vacancies.Keys).Distinct();
        foreach (var party in allParties)
        {
            var e = elected.GetValueOrDefault(party);
            var cg = crossGains.GetValueOrDefault(party);
            var cl = crossLosses.GetValueOrDefault(party);
            var bg = byElectionGains.GetValueOrDefault(party);
            var bl = byElectionLosses.GetValueOrDefault(party);
            var v = vacancies.GetValueOrDefault(party);
            result[party] = new SeatBreakdown(e - cl - bl - v + cg + bg, e, cg, cl, bg, bl, v);
        }
        return result;
    }

    private int GetVacantSeatCount()
    {
        var parlState = State.CurrentParliamentaryState;
        if (parlState == null) return 0;
        return parlState.Values.Count(s => s.CurrentHolder == null);
    }
}
